<?xml version="1.0" encoding="utf-8"?>
<!--
  amm GUI (amm.exe) の発行プロファイル — Windows x64 / 単一 exe / self-contained。
  発行条件の正本。CI とローカルで同一条件を保証する (構成案 §Publish)。

  取り込み方法: src\apps\Amm\Amm.csproj が -p:AmmPublishProfile=win-x64-singlefile 指定時に
  本ファイルを <Import> する (絶対パスの PublishProfile は SDK が解決しないため)。
  tools\publish.cmd から呼ばれる。通常の build/test には影響しない (プロパティ未指定時は未取り込み)。

  出力先 (PublishDir) はここで指定しない。amm.exe と amm-mcp.exe を同一フォルダ
  artifacts/publish へフラットに統合し MSI がツリー丸ごとを harvest するため、
  出力先はオーケストレーション側 (tools/publish.cmd の -o) で与える。
-->
<Project>
  <PropertyGroup>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- WinForms のため Trimmed は無効 (リフレクション破損回避)。 -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
