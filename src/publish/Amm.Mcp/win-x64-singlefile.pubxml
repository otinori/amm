<?xml version="1.0" encoding="utf-8"?>
<!--
  amm-mcp (amm-mcp.exe) の発行プロファイル — Windows x64 / 単一 exe / self-contained。
  stdio MCP サーバ / CLI / REPL。amm.exe と同一フォルダ (artifacts/publish) へ統合する。

  取り込み方法: src\apps\Amm.Mcp\Amm.Mcp.csproj が -p:AmmPublishProfile=win-x64-singlefile
  指定時に本ファイルを <Import> する。出力先は tools/publish.cmd の -o で与える
  (Amm 側 pubxml のコメント参照)。
-->
<Project>
  <PropertyGroup>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
